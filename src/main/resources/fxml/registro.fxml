<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="600.0" prefWidth="800.0" styleClass="registro-background"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.RegistroController">
    <children>
        <VBox alignment="CENTER" maxHeight="560.0" maxWidth="500.0"
              spacing="12.0" styleClass="registro-panel">
            <children>
                <Text styleClass="registro-title" text="Crear Cuenta">
                    <font><Font size="24.0" /></font>
                </Text>

                <HBox spacing="10.0">
                    <TextField fx:id="txtNombre" promptText="Nombre" HBox.hgrow="ALWAYS" />
                    <TextField fx:id="txtApellido" promptText="Apellido" HBox.hgrow="ALWAYS" />
                </HBox>

                <TextField fx:id="txtUsuario" promptText="Usuario" />
                <PasswordField fx:id="txtContrasena" promptText="Contrasena (min. 8 caracteres)" />
                <PasswordField fx:id="txtConfirmarContrasena" promptText="Confirmar contrasena" />

                <HBox spacing="10.0">
                    <TextField fx:id="txtTelefono" promptText="Telefono" HBox.hgrow="ALWAYS" />
                    <TextField fx:id="txtEmail" promptText="Email" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER" spacing="20.0">
                    <Button fx:id="btnRegistrarse" mnemonicParsing="false"
                            onAction="#handleRegistrarse" prefWidth="150.0"
                            styleClass="btn-primary" text="Registrarse" />
                    <Button fx:id="btnCancelar" mnemonicParsing="false"
                            onAction="#handleCancelar" prefWidth="150.0"
                            styleClass="btn-secondary" text="Cancelar" />
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>